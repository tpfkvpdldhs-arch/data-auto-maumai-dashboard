# Required for API routes (server-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-or-secret-key>

# Required for /admin override APIs
ADMIN_API_TOKEN=<your-admin-api-token>

# Required for customer-facing /viewer route
PUBLIC_VIEW_TOKEN=<your-public-view-token>
